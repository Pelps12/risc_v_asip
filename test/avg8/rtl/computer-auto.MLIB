
#@VERSION { 3.00 }
#@LIB { computer }
#@UNIT 1/10ps
#@SYN_TOOL{DC}
@MLIB {
     NAME	MEMB32W4096
     KIND	R1
     BITWIDTH	32
     DELAY	x2
     WORD	4096
     WRITE_SYNC	YES
     DEFMOD {
         in             ter (11..0)    RA1              /* ra:1 */;
         out            ter (31..0)    RD1              /* rd:1 */;
         in             ter (0..0)     RE1              /* re:1 */;
         in             ter (0..0)     RCLK1            /* rclk:1 */;
     }
}
#@END { computer }
